# /graphql/user/graphql/users.graphqls
extend type UserMutations {
    assignRoles(request: AssignRolesRequest): ID! @requiresPermissions(permissions: ["AssignRoles"])
    unassignRoles(request: AssignRolesRequest): ID! @requiresPermissions(permissions: ["UnassignRoles"])
}

input AssignRolesRequest {
    organizationId: ID!
    userId: ID!,
    roles: [ID!]!
}
