# /graphql/brand/graphql/brands.graphqls
extend type BrandMutations {
    createRole(request: CreateBrandRoleRequest!): ID!
    assignStudios(brandId: ID! studios: [ID!]!): Boolean!
}

input CreateBrandRoleRequest {
    organizationId: ID!
    name: String!
    description: String!
    permissions: [ID!]
}
