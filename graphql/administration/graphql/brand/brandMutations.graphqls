# /graphql/brand/graphql/brands.graphqls
extend type BrandMutations {
    createRole(request: CreateBrandRoleRequest!): ID!
    assignStudios(request: AssignStudiosRequest!): Boolean!
}

input CreateBrandRoleRequest {
    organizationId: ID!
    name: String!
    description: String!
    permissions: [ID!]
}

input AssignStudiosRequest {
    organizationId: ID!
    studios: [ID!]!
}
