# /graphql/brand/graphql/brands.graphqls
extend type BrandMutations {
    createRole(request: CreateBrandRoleRequest!): ID! @requiresPermissions(permissions: ["CreateBrandRole"])
    assignStudios(request: AssignStudiosRequest!): Boolean! @requiresPermissions(permissions: ["AssignStudios"])
}

input CreateBrandRoleRequest {
    organizationId: ID!
    name: String!
    description: String!
    permissions: [ID!]
}

input AssignStudiosRequest {
    organizationId: ID!
    studios: [ID!]!
}
