extend type RoleQueries {
    role(request: GetOrganizationRoleRequest!): Role @requiresPermissions(permissions: ["GetOrganizationRole"])
}

input GetOrganizationRoleRequest {
    organizationId: ID!
    roleId: ID!
}

type Role {
    id: ID!
    name: String!
    description: String!
    permissions: [Permission!]!
}
