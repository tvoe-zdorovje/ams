extend type StudioMutations {
    createStudio(request: CreateStudioRequest!): ID!
    updateStudio(request: UpdateStudioRequest!): ID! @requiresPermissions(permissions: ["UpdateStudio"])
}

input CreateStudioRequest {
    organizationId: ID! # brand id
    name: String!
    description: String!
}

input UpdateStudioRequest {
    organizationId: ID!
    name: String!
    description: String!
}
