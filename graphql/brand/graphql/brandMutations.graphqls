extend type BrandMutations {
    createBrand(request: CreateBrandRequest!): ID!
    updateBrand(request: UpdateBrandRequest!): ID! @requiresPermissions(permissions: ["UpdateBrand"])
}

input CreateBrandRequest {
    name: String!
    description: String!
}

input UpdateBrandRequest {
    organizationId: ID!
    name: String!
    description: String!
}
