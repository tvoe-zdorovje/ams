# service

DBHOST=studio_db
DBPORT=5432
DBNAME=studio_db

DBUSER=stsportal
DBPASS=stsportal

# postgres

LANG=en_US.utf8
POSTGRES_LOG_STATEMENT=all
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_HOST=${DBHOST}
POSTGRES_PORT=${DBPORT}
# default DB created on start up
POSTGRES_DB=postgres
POSTGRES_DB_NAME=${DBNAME}

# liquibase

LIQUIBASE_COMMAND_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB_NAME}
LIQUIBASE_COMMAND_USERNAME=stsliquibase
LIQUIBASE_COMMAND_PASSWORD=stsliquibase
LIQUIBASE_COMMAND_CHANGELOG_FILE=changelog/changelog.yaml

PGHOST=${POSTGRES_HOST}
PGPORT=${POSTGRES_PORT}
PGUSER=${LIQUIBASE_COMMAND_USERNAME}
PGPASSWORD=${LIQUIBASE_COMMAND_PASSWORD}
PGDATABASE=${POSTGRES_DB_NAME}

# kafka

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

KAFKA_STUDIO_EVENTS_TOPIC=v1.studios.studio
KAFKA_STUDIO_EVENTS_TOPIC_REPLICATION_FACTOR=1
KAFKA_STUDIO_EVENTS_TOPIC_PARTITIONS_COUNT=3